# Copy to .env (for local CLI) or set in Render dashboard (for deployment).

# === Core screener (required for CLI + API) ===
ANTHROPIC_API_KEY=sk-ant-...
SEC_USER_AGENT=Ramon Leal Doris rleal@topaz.com.mx

# === API service — only needed when running api/main.py ===
# Supabase project URL and service-role key (NOT the anon key).
# Get these from Supabase dashboard → Settings → API.
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Shared secret between Next.js frontend and this API.
# In production: generated by Render (`generateValue: true` in render.yaml)
# and copied into Vercel as SCREENER_API_SECRET.
# For local testing: set any random string and use the same value in the
# frontend .env.local.
INTERNAL_API_SECRET=dev-secret-change-me

# Optional: extra comma-separated CORS origins beyond the defaults
# (localhost:3000, localhost:3001, internal-platform-pearl.vercel.app)
CORS_EXTRA_ORIGINS=
